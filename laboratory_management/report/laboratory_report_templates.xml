<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Report Action -->
    <record id="action_report_laboratory_results" model="ir.actions.report">
        <field name="name">Patient Laboratory Report</field>
        <field name="model">hospital.laboratory</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">laboratory_management.report_laboratory_results_template</field>
        <field name="report_file">laboratory_management.report_laboratory_results_template</field>
        <field name="binding_model_id" ref="model_hospital_laboratory"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Report Template -->
    <template id="report_laboratory_results_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; color: #333333; padding: 20px;">
                        <!-- Header / Title -->
                        <div class="row" style="border-bottom: 3px solid #0284c7; padding-bottom: 10px; margin-bottom: 25px;">
                            <div class="col-7">
                                <h2 style="color: #0284c7; font-weight: bold; margin: 0;">LABORATORY TEST REPORT</h2>
                                <span style="font-size: 14px; color: #666666;">Hospital Laboratory Services</span>
                            </div>
                            <div class="col-5 text-end" style="margin-top: 15px;">
                                <h4 style="font-weight: bold; color: #334155; margin: 0;" t-field="o.name"/>
                            </div>
                        </div>

                        <!-- Patient and Request Information Table -->
                        <div style="background-color: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; padding: 15px; margin-bottom: 30px;">
                            <table style="width: 100%; font-size: 13px; line-height: 1.8; border-collapse: collapse;">
                                <tr>
                                    <td style="width: 18%; font-weight: bold; color: #475569;">Patient Name:</td>
                                    <td style="width: 32%; color: #1e293b;" t-field="o.patient_id.name"/>
                                    <td style="width: 18%; font-weight: bold; color: #475569;">Request Date:</td>
                                    <td style="width: 32%; color: #1e293b;" t-field="o.request_date" t-options='{"widget": "date"}'/>
                                </tr>
                                <tr>
                                    <td style="font-weight: bold; color: #475569;">Patient ID:</td>
                                    <td style="color: #1e293b;" t-field="o.patient_ref"/>
                                    <td style="font-weight: bold; color: #475569;">Prescribing Doctor:</td>
                                    <td style="color: #1e293b;" t-field="o.doctor_id.name"/>
                                </tr>
                                <tr>
                                    <td style="font-weight: bold; color: #475569;">Age / Gender:</td>
                                    <td style="color: #1e293b;">
                                        <span t-field="o.patient_id.age"/> Years / <span t-field="o.patient_id.gender" style="text-transform: capitalize;"/>
                                    </td>
                                    <td style="font-weight: bold; color: #475569;">Status:</td>
                                    <td style="color: #1e293b;">
                                        <span t-field="o.state" style="text-transform: uppercase; font-weight: bold; color: #16a34a;" t-if="o.state == 'completed'">Completed</span>
                                        <span t-field="o.state" style="text-transform: uppercase; color: #ea580c;" t-if="o.state != 'completed'">Pending</span>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- Results Table -->
                        <h4 style="color: #0284c7; border-bottom: 2px solid #e2e8f0; padding-bottom: 5px; margin-bottom: 15px; font-weight: bold;">TEST RESULTS</h4>
                        <table style="width: 100%; border-collapse: collapse; font-size: 13px; margin-bottom: 40px;">
                            <thead>
                                <tr style="background-color: #0284c7; color: #ffffff; text-align: left;">
                                    <th style="padding: 10px; border: 1px solid #0284c7;">Test Code</th>
                                    <th style="padding: 10px; border: 1px solid #0284c7;">Test Name</th>
                                    <th style="padding: 10px; border: 1px solid #0284c7;">Category</th>
                                    <th style="padding: 10px; border: 1px solid #0284c7; text-align: center;">Result</th>
                                    <th style="padding: 10px; border: 1px solid #0284c7; text-align: center;">Reference Range</th>
                                    <th style="padding: 10px; border: 1px solid #0284c7; text-align: center;">Unit</th>
                                    <th style="padding: 10px; border: 1px solid #0284c7; text-align: center;">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.result_ids" t-as="result">
                                    <tr style="border-bottom: 1px solid #e2e8f0;">
                                        <td style="padding: 10px; font-weight: bold; color: #475569;" t-field="result.test_id.code"/>
                                        <td style="padding: 10px; color: #1e293b;" t-field="result.test_id.name"/>
                                        <td style="padding: 10px; color: #64748b; text-transform: capitalize;" t-field="result.test_id.category"/>
                                        <td style="padding: 10px; font-weight: bold; text-align: center; color: #0284c7;" t-field="result.result_value"/>
                                        <td style="padding: 10px; text-align: center; color: #64748b;" t-field="result.normal_range"/>
                                        <td style="padding: 10px; text-align: center; color: #64748b;" t-field="result.unit"/>
                                        <td style="padding: 10px; text-align: center;">
                                            <span style="font-size: 11px; padding: 2px 6px; border-radius: 4px; font-weight: bold; background-color: #dcfce7; color: #15803d;" t-if="result.state == 'verified'">Verified</span>
                                            <span style="font-size: 11px; padding: 2px 6px; border-radius: 4px; font-weight: bold; background-color: #fee2e2; color: #b91c1c;" t-if="result.state != 'verified'">Draft</span>
                                        </td>
                                    </tr>
                                    <tr t-if="result.remarks" style="background-color: #f8fafc; border-bottom: 1px solid #e2e8f0;">
                                        <td colspan="7" style="padding: 5px 10px; font-size: 11px; color: #64748b; font-style: italic;">
                                            <strong>Remarks:</strong> <span t-field="result.remarks"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- Verification and Signatures -->
                        <div class="row" style="margin-top: 50px; page-break-inside: avoid;">
                            <div class="col-6" style="font-size: 12px; color: #64748b;">
                                <strong style="color: #475569;">Notes:</strong>
                                <p style="margin-top: 5px; line-height: 1.5;">This is an electronically generated and verified medical report. In case of any clinical queries, please contact the hospital laboratory services desk.</p>
                            </div>
                            <div class="col-6 text-end" style="font-size: 13px;">
                                <div style="margin-bottom: 40px; border-bottom: 1px solid #94a3b8; width: 80%; display: inline-block;"></div>
                                <div>
                                    <strong style="color: #334155;">Verified By:</strong>
                                    <div style="color: #1e293b; margin-top: 5px; font-weight: bold;">
                                        <span t-if="o.result_ids and o.result_ids[0].verified_by" t-field="o.result_ids[0].verified_by.name"/>
                                        <span t-if="not (o.result_ids and o.result_ids[0].verified_by)">Laboratory Technologist</span>
                                    </div>
                                    <div style="color: #64748b; font-size: 11px;" t-if="o.result_ids and o.result_ids[0].verification_date">
                                        Verified on <span t-field="o.result_ids[0].verification_date" t-options='{"widget": "datetime"}'/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
