<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for Laboratory Request -->
        <record id="seq_hospital_laboratory" model="ir.sequence">
            <field name="name">Laboratory Request</field>
            <field name="code">hospital.laboratory</field>
            <field name="prefix">LR-%(range_year)s-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequence for Sample Collection -->
        <record id="seq_laboratory_sample" model="ir.sequence">
            <field name="name">Laboratory Sample</field>
            <field name="code">laboratory.sample</field>
            <field name="prefix">SMP-%(range_year)s-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
