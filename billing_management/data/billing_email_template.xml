<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="email_template_hospital_bill" model="mail.template">
            <field name="name">Hospital Bill: Send by Email</field>
            <field name="model_id" ref="billing_management.model_hospital_billing"/>
            <field name="subject">Invoice {{ object.name }} from Hospital</field>
            <field name="email_to">{{ object.patient_id.email }}</field>
            <field name="body_html" type="html">
                <div style="font-family: Arial, sans-serif; font-size: 14px; color: #333333;">
                    <p>Dear <t t-out="object.patient_id.name"/>,</p>
                    <p>We hope this email finds you well.</p>
                    <p>Please find attached your invoice <strong><t t-out="object.name"/></strong> dated <t t-out="object.bill_date"/> for the amount of <strong><t t-out="object.amount"/></strong>.</p>
                    <p><strong>Invoice Details:</strong></p>
                    <ul>
                        <li><strong>Bill Number:</strong> <t t-out="object.name"/></li>
                        <li><strong>Amount Due:</strong> <t t-out="object.amount"/></li>
                        <li><strong>Doctor:</strong> <t t-out="object.appointment_id.doctor_id.name"/></li>
                        <li><strong>Date:</strong> <t t-out="object.bill_date"/></li>
                    </ul>
                    <p>If you have any questions, please do not hesitate to contact us.</p>
                    <p>Thank you for choosing our hospital!</p>
                    <br/>
                    <p>Best regards,</p>
                    <p><strong>Hospital Administration</strong></p>
                </div>
            </field>
            <field name="report_template_ids" eval="[(4, ref('action_report_hospital_bill'))]"/>
        </record>
    </data>
</odoo>
