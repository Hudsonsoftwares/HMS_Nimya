<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Insurance Executive Group -->
        <record id="group_insurance_executive" model="res.groups">
            <field name="name">Insurance Executive</field>
            <field name="category_id" ref="Clinic_master.module_category_hms"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Insurance Manager Group -->
        <record id="group_insurance_manager" model="res.groups">
            <field name="name">Insurance Manager</field>
            <field name="category_id" ref="Clinic_master.module_category_hms"/>
            <field name="implied_ids" eval="[(4, ref('group_insurance_executive'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
