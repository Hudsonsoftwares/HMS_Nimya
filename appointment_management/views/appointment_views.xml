<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List/Tree View -->
    <record id="view_hospital_appointment_tree" model="ir.ui.view">
        <field name="name">hospital.appointment.tree</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <list string="Appointments" decoration-info="state == 'draft'" decoration-warning="state == 'waiting'" decoration-success="state == 'done'" decoration-danger="state == 'cancel'" decoration-muted="state == 'noshow'">
                <field name="name" decoration-bf="1"/>
                <field name="token_number" string="Token" decoration-bf="1"/>
                <field name="patient_id"/>
                <field name="patient_name"/>
                <field name="appointment_date"/>
                <field name="appointment_time" widget="float_time"/>
                <field name="doctor_id" widget="many2one_avatar"/>
                <field name="visit_type" widget="badge"/>
                <field name="priority" widget="badge" decoration-danger="priority == 'emergency'" decoration-warning="priority == 'urgent'"/>
                <field name="payment_type"/>
                <field name="consultation_fees"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state in ('confirmed','done')" decoration-warning="state == 'waiting'" decoration-danger="state == 'cancel'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_hospital_appointment_form" model="ir.ui.view">
        <field name="name">hospital.appointment.form</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <form string="Appointment">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_arrive" string="Patient Arrived" type="object" class="oe_highlight" invisible="state != 'confirmed'"/>
                    <button name="action_start_consultation" string="Start Consultation" type="object" class="oe_highlight" invisible="state != 'waiting'"/>
                    <button name="action_complete" string="Complete Consultation" type="object" class="oe_highlight" invisible="state != 'consultation'"/>
                    
                    <button name="action_hold" string="Hold Patient" type="object" invisible="state != 'waiting' or is_on_hold == True"/>
                    <button name="action_resume" string="Resume Patient" type="object" invisible="is_on_hold == False"/>
                    
                    <button name="action_no_show" string="No Show" type="object" invisible="state not in ('draft', 'confirmed', 'waiting')"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('done', 'cancel')"/>
                    <button name="action_draft" string="Reset to Draft" type="object" invisible="state != 'cancel'"/>
                    
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,waiting,consultation,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_patient_profile" type="object" class="oe_stat_button" icon="fa-user" string="Patient Profile"/>
                        <button name="action_view_insurance_case" type="object" class="oe_stat_button" icon="fa-shield" string="Insurance Case" invisible="not insurance_case_id"/>
                    </div>
                    
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group string="Patient Demographics">
                            <field name="patient_id" options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="patient_id_ref"/>
                            <field name="patient_name"/>
                            <field name="patient_phone"/>
                            <field name="patient_gender"/>
                            <field name="patient_age"/>
                            <field name="patient_dob"/>
                            <field name="patient_blood_group"/>
                        </group>
                        <group string="Schedule &amp; Doctor">
                            <field name="doctor_id"/>
                            <field name="department_id"/>
                            <field name="appointment_date"/>
                            <field name="appointment_time" widget="float_time"/>
                            <field name="token_number"/>
                            <field name="visit_type"/>
                            <field name="priority"/>
                            <field name="is_on_hold" readonly="1" invisible="not is_on_hold"/>
                        </group>
                    </group>
                    
                    <group>
                        <group string="Billing &amp; Insurance">
                            <field name="payment_type"/>
                            <field name="consultation_fees"/>
                            <field name="previous_visit_date"/>
                        </group>
                        <group string="Insurance Specifications" invisible="not has_insurance">
                            <field name="has_insurance" readonly="1"/>
                            <field name="insurance_provider_id"/>
                            <field name="policy_number"/>
                            <field name="insurance_expiry_date"/>
                            <field name="insurance_case_id"/>
                            <field name="insurance_summary" readonly="1" string="Insurance Summary"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Clinical Notes" name="clinical_notes">
                            <group>
                                <field name="chief_complaint"/>
                                <field name="symptoms"/>
                                <field name="notes" placeholder="Internal checkout details, prescriptions or remarks..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_hospital_appointment_kanban" model="ir.ui.view">
        <field name="name">hospital.appointment.kanban</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" quick_create="0" records_draggable="0">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="patient_name"/>
                <field name="doctor_id"/>
                <field name="appointment_date"/>
                <field name="appointment_time"/>
                <field name="token_number"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="patient_name"/> (<field name="name"/>)
                                </strong>
                                <div style="margin-top: 5px;">
                                    <span>Token: </span><strong><field name="token_number"/></strong>
                                </div>
                                <div>
                                    <span>Doctor: </span><field name="doctor_id"/>
                                </div>
                                <div>
                                    <span>Time: </span><field name="appointment_time" widget="float_time"/>
                                </div>
                                <div>
                                    <span>Date: </span><field name="appointment_date"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Calendar View -->
    <record id="view_hospital_appointment_calendar" model="ir.ui.view">
        <field name="name">hospital.appointment.calendar</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <calendar string="Appointments" date_start="appointment_datetime" color="doctor_id" quick_create="0" mode="week">
                <field name="patient_name"/>
                <field name="doctor_id"/>
                <field name="token_number"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_hospital_appointment_search" model="ir.ui.view">
        <field name="name">hospital.appointment.search</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <search string="Search Appointments">
                <!-- Search text fields -->
                <field name="name" string="Appointment ID"/>
                <field name="patient_id" filter_domain="['|', '|', ('patient_id.patient_id', 'ilike', self), ('patient_name', 'ilike', self), ('patient_phone', 'ilike', self)]" string="Patient Search (ID/Name/Phone)"/>
                <field name="doctor_id"/>
                <field name="department_id"/>
                <field name="token_number"/>

                <!-- Preset filters -->
                <filter string="Today" name="today" domain="[('appointment_date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="Tomorrow" name="tomorrow" domain="[('appointment_date', '=', (context_today() + datetime.timedelta(days=1)).strftime('%Y-%m-%d'))]"/>
                <filter string="This Week" name="this_week" domain="[
                    ('appointment_date', '&gt;=', (context_today() - datetime.timedelta(days=context_today().weekday())).strftime('%Y-%m-%d')),
                    ('appointment_date', '&lt;=', (context_today() + datetime.timedelta(days=6-context_today().weekday())).strftime('%Y-%m-%d'))
                ]"/>
                <separator/>
                <filter string="Waiting Queue" name="waiting" domain="[('state', '=', 'waiting')]"/>
                <filter string="In Consultation" name="consultation" domain="[('state', '=', 'consultation')]"/>
                <filter string="Completed" name="done" domain="[('state', '=', 'done')]"/>
                <filter string="Cancelled" name="cancel" domain="[('state', '=', 'cancel')]"/>
                <separator/>
                <filter string="Emergency" name="visit_emergency" domain="[('visit_type', '=', 'emergency')]"/>
                <filter string="Follow-up" name="visit_followup" domain="[('visit_type', '=', 'followup')]"/>
                <separator/>
                <filter string="Insurance Patients" name="pay_insurance" domain="[('payment_type', '=', 'insurance')]"/>
                <filter string="Cash Patients" name="pay_cash" domain="[('payment_type', '=', 'cash')]"/>

                <!-- Group by filters -->
                <group expand="0" string="Group By">
                    <filter string="Doctor" name="group_doctor" context="{'group_by': 'doctor_id'}"/>
                    <filter string="Department" name="group_dept" context="{'group_by': 'department_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'appointment_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_hospital_appointment" model="ir.actions.act_window">
        <field name="name">Appointments</field>
        <field name="res_model">hospital.appointment</field>
        <field name="view_mode">list,kanban,calendar,form</field>
        <field name="search_view_id" ref="view_hospital_appointment_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Book a new appointment!
            </p>
        </field>
    </record>

    <record id="action_hospital_appointment_today" model="ir.actions.act_window">
        <field name="name">Today's Appointments</field>
        <field name="res_model">hospital.appointment</field>
        <field name="view_mode">list,kanban,calendar,form</field>
        <field name="domain">[('appointment_date', '=', context_today().strftime('%Y-%m-%d'))]</field>
        <field name="context">{'search_default_today': 1}</field>
        <field name="search_view_id" ref="view_hospital_appointment_search"/>
    </record>

    <!-- Menus under Root Menu -->
    <menuitem id="menu_hospital_appointment_list"
              name="Appointments"
              parent="menu_hospital_appointment_root"
              action="action_hospital_appointment"
              sequence="10"/>

    <menuitem id="menu_hospital_appointment_today"
              name="Today's Appointments"
              parent="menu_hospital_appointment_root"
              action="action_hospital_appointment_today"
              sequence="15"/>
</odoo>