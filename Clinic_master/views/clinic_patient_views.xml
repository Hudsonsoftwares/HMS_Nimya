<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Patient List View -->
    <record id="view_clinic_patient_tree" model="ir.ui.view">
        <field name="name">clinic.patient.list</field>
        <field name="model">clinic.patient</field>
        <field name="arch" type="xml">
            <list string="Patients" decoration-success="status == 'active'" decoration-info="status == 'inactive'" decoration-warning="status == 'blocked'" decoration-danger="status == 'deceased'">
                <field name="patient_id" readonly="1"/>
                <field name="name"/>
                <field name="gender"/>
                <field name="age"/>
                <field name="blood_group"/>
                <field name="mobile"/>
                <field name="registration_date"/>
                <field name="status" widget="badge" decoration-success="status == 'active'" decoration-info="status == 'inactive'" decoration-warning="status == 'blocked'" decoration-danger="status == 'deceased'"/>
            </list>
        </field>
    </record>

    <!-- Patient Form View -->
    <record id="view_clinic_patient_form" model="ir.ui.view">
        <field name="name">clinic.patient.form</field>
        <field name="model">clinic.patient</field>
        <field name="arch" type="xml">
            <form string="Patient Profile">
                <header>
                    <button name="%(Clinic_master.action_report_clinic_patient_card)d" string="Print Card" type="action" class="oe_highlight"/>
                    <button name="action_archive_patient" string="Archive Patient" type="object" invisible="status in ('inactive', 'blocked')" class="btn-secondary"/>
                    <button name="action_unarchive_patient" string="Activate Patient" type="object" invisible="status == 'active'" class="btn-primary"/>
                    <field name="status" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <h1>
                            <field name="patient_id" readonly="1"/>
                        </h1>
                        <h2>
                            <div class="o_row">
                                <field name="first_name" placeholder="First Name" required="1" style="margin-right: 10px;"/>
                                <field name="last_name" placeholder="Last Name"/>
                            </div>
                        </h2>
                    </div>
                    <notebook>
                        <!-- Tab 1: Patient Information -->
                        <page string="Patient Information" name="patient_info">
                            <group>
                                <group string="Demographics">
                                    <field name="gender" required="1"/>
                                    <field name="date_of_birth" required="1"/>
                                    <field name="age" readonly="1"/>
                                    <field name="blood_group"/>
                                    <field name="qatar_id_number"/>
                                    <field name="qatar_id_expiry"/>
                                </group>
                                <group string="Communications &amp; Categorization">
                                    <field name="mobile" required="1"/>
                                    <field name="email" widget="email"/>
                                    <field name="nationality_id" options="{'no_create': True, 'no_open': True}"/>
                                    <field name="marital_status"/>
                                    <field name="category_id"/>
                                    <field name="active" invisible="1"/>
                                </group>
                            </group>
                        </page>

                        <!-- Tab 2: Address -->
                        <page string="Address" name="address">
                            <group>
                                <group string="Address Details">
                                    <field name="building"/>
                                    <field name="street"/>
                                    <field name="city"/>
                                </group>
                                <group string="Regional Settings">
                                    <field name="state_id" options="{'no_open': True, 'no_create': True}"/>
                                    <field name="country_id" options="{'no_open': True, 'no_create': True}"/>
                                    <field name="zip"/>
                                </group>
                            </group>
                        </page>

                        <!-- Tab 3: Emergency Contact -->
                        <page string="Emergency Contact" name="emergency_contact">
                            <group>
                                <group string="Relationship">
                                    <field name="emergency_name"/>
                                    <field name="emergency_relationship_id" options="{'no_create_edit': True}"/>
                                </group>
                                <group string="Contact Numbers">
                                    <field name="emergency_mobile"/>
                                    <field name="emergency_alternate"/>
                                </group>
                            </group>
                        </page>

                        <!-- Tab 4: Insurance Information -->
                        <page string="Insurance Information" name="insurance_info">
                            <group>
                                <group string="Coverage Check">
                                    <field name="has_insurance"/>
                                    <field name="insurance_provider_id" invisible="not has_insurance" required="has_insurance"/>
                                    <field name="insurance_card_file" filename="insurance_card_filename" widget="binary" string="Upload Insurance Card"/>
                                    <field name="insurance_card_filename" invisible="1"/>
                                </group>
                                <group string="Policy Specifications" invisible="not has_insurance">
                                    <field name="policy_number"/>
                                    <field name="membership_number"/>
                                    <field name="insurance_expiry_date"/>
                                </group>
                            </group>
                        </page>

                        <!-- Tab 5: Medical Information -->
                        <page string="Medical Information" name="medical_info">
                            <group string="History &amp; Observations">
                                <field name="allergies" placeholder="List any food or drug allergies..."/>
                                <field name="chronic_diseases" placeholder="Chronic conditions (e.g. Diabetes, Hypertension)..."/>
                                <field name="current_medications" placeholder="List active medications..."/>
                                <field name="previous_surgeries" placeholder="List past surgeries..."/>
                                <field name="medical_remarks" placeholder="Other medical remarks..."/>
                            </group>
                        </page>

                        <!-- Tab 6: Attachments -->
                        <page string="Attachments" name="attachments">
                            <group>
                                <group string="Identifications">
                                    <field name="qatar_id_file" filename="qatar_id_filename" widget="binary"/>
                                    <field name="qatar_id_filename" invisible="1"/>
                                </group>
                                <group string="Medical Documents">
                                    <field name="medical_report_file" filename="medical_report_filename" widget="binary"/>
                                    <field name="medical_report_filename" invisible="1"/>
                                    
                                    <field name="referral_letter_file" filename="referral_letter_filename" widget="binary"/>
                                    <field name="referral_letter_filename" invisible="1"/>
                                </group>
                            </group>
                        </page>

                        <!-- Tab 7: System Information -->
                        <page string="System Information" name="system_info">
                            <group>
                                <group string="Registration Details">
                                    <field name="registration_date" readonly="1"/>
                                </group>
                                <group string="Modification Logs">
                                    <field name="write_date" string="Last Updated" readonly="1"/>
                                    <field name="partner_id" readonly="1" groups="base.group_no_one"/>
                                </group>
                            </group>
                            <separator string="Notes"/>
                            <field name="notes" placeholder="Enter patient notes or summary here..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Patient Search View -->
    <record id="view_clinic_patient_search" model="ir.ui.view">
        <field name="name">clinic.patient.search</field>
        <field name="model">clinic.patient</field>
        <field name="arch" type="xml">
            <search string="Search Patients">
                <field name="name" filter_domain="['|', '|', ('first_name', 'ilike', self), ('last_name', 'ilike', self), ('patient_id', 'ilike', self)]"/>
                <field name="patient_id"/>
                <field name="mobile"/>
                <field name="email"/>
                <filter string="Active Patients" name="active_patients" domain="[('status', '=', 'active')]"/>
                <filter string="Inactive Patients" name="inactive_patients" domain="[('status', '=', 'inactive')]"/>
                <filter string="Blocked Patients" name="blocked_patients" domain="[('status', '=', 'blocked')]"/>
                <filter string="Deceased Patients" name="deceased_patients" domain="[('status', '=', 'deceased')]"/>
                <group expand="0" string="Group By">
                    <filter string="Gender" name="group_gender" context="{'group_by': 'gender'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Blood Group" name="group_blood_group" context="{'group_by': 'blood_group'}"/>
                    <filter string="Category" name="group_category" context="{'group_by': 'category_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action for Patients -->
    <record id="action_clinic_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">clinic.patient</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_clinic_patient_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first patient!
            </p>
        </field>
    </record>
</odoo>
